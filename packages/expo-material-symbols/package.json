{
  "name": "@expo/material-symbols",
  "version": "0.1.0",
  "sideEffects": false,
  "files": [
    "icons",
    "bin",
    "NOTICE"
  ],
  "bin": {
    "add-icon": "./bin/add-icon.mjs"
  },
  "exports": {
    "./*.xml": {
      "types": "./icons/*.xml.d.ts",
      "default": "./icons/*.xml"
    }
  },
  "scripts": {
    "generate": "bun run generate.ts",
    "update-icons": "bun run update-icons.ts",
    "add-icon": "bun run add-icon.ts",
    "build-cli": "bun build add-icon.ts --target node --format esm --outfile bin/add-icon.mjs",
    "typecheck": "tsc",
    "test": "bun test",
    "prepare": "bun run build-cli",
    "prepublishOnly": "bun run generate.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
