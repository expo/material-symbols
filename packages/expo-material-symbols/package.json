{
  "name": "@expo/material-symbols",
  "version": "0.1.0",
  "sideEffects": false,
  "files": [
    "icons",
    "modules",
    "bin",
    "NOTICE"
  ],
  "bin": {
    "add-icon": "./bin/add-icon.mjs"
  },
  "exports": {
    "./*": "./modules/*.ts"
  },
  "scripts": {
    "generate": "bun run generate.ts",
    "update-icons": "bun run update-icons.ts",
    "add-icon": "bun run add-icon.ts",
    "build-cli": "bun build add-icon.ts --target node --format esm --outfile bin/add-icon.mjs --external @iconify/tools",
    "typecheck": "tsc",
    "test": "bun test",
    "prepare": "bun run generate.ts && bun run build-cli"
  },
  "dependencies": {
    "@iconify/tools": "^5.0.6"
  },
  "devDependencies": {
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
